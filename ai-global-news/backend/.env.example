# dev | prod
AIGN_APP_ENV=dev

AIGN_APP_NAME=AI Global News API
AIGN_APP_VERSION=0.1.0
AIGN_DEBUG=true
AIGN_LOG_LEVEL=DEBUG

# 本地开发默认 SQLite（推荐）
AIGN_DATABASE_URL=sqlite:///./ai_global_news_dev.db

# 采集/入库失败重试
AIGN_INGEST_COLLECT_MAX_ATTEMPTS=3
AIGN_INGEST_COLLECT_BACKOFF_SECONDS=1.0
AIGN_INGEST_DB_MAX_ATTEMPTS=2
AIGN_INGEST_DB_BACKOFF_SECONDS=0.5

# 可按环境覆盖数据库文件位置（示例）
# AIGN_DATABASE_URL=sqlite:///./ai_global_news_local.db
